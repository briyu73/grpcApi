<UserControl x:Class="FlewsApp.Modules.DataLibraryEditor.Views.NamingToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:aux="http://swordfish.com.au/WPF/1.0"
             xmlns:resourcesConverters="clr-namespace:FlewsApp.Modules.Resources.Converters;assembly=FlewsApp.Common.Resources"
             xmlns:sf="http://swordfish.com.au/WPF/1.0"
             xmlns:uiConverters="clr-namespace:FlewsApp.Modules.UI.Converters;assembly=FlewsApp.Modules.UI"
             xmlns:converters="clr-namespace:FlewsApp.Modules.DataLibraryEditor.Converters"
             xmlns:dsData="clr-namespace:FlewsApp.Modules.DataStore.Data;assembly=FlewsApp.Modules.DataStore"
             xmlns:prism="http://prismlibrary.com/"
             
             FontFamily="{DynamicResource AppFontFamily}"
             FontSize="{DynamicResource AppFontSize}"
             Background="{DynamicResource WindowBackgroundBrush}"
             x:Name="userControl">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FlewsApp.Modules.UI;component/Resources/FlewsResourceDictionary.xaml"/>
        <ResourceDictionary Source="/FlewsApp.Modules.DataLibraryEditor;component/Resources/GroupStyles.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <prism:Dialog.WindowStyle>
    <Style TargetType="Window">
      <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterOwner" />
      <Setter Property="SizeToContent" Value="Manual"/>
      <Setter Property="ShowInTaskbar" Value="True"/>
    </Style>
  </prism:Dialog.WindowStyle>
  
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" MinWidth="830"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="200"/>
    </Grid.ColumnDefinitions>

    <!-- DLE Item Naming Records  -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition />
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <GroupBox MinHeight="100" Margin="5,0,5,0">
        <GroupBox.Header>
          <StackPanel Orientation="Horizontal" Margin="5">
            <TextBlock Text="Platforms, Missiles and Systems" FontWeight="Bold" />
            <TextBlock Margin="5, 0" FontStyle="Italic"
                   Text="(Items with DIS Values)"/>
          </StackPanel>
        </GroupBox.Header>

        <Grid>
          <FrameworkElement x:Name="frameWorkElementProxy2" Visibility="Collapsed"/>
          
          <DataGrid ItemsSource="{Binding ItemNamingRecords.CollectionView}"
                  SelectedValue="{Binding SelectedItemNamingRecord}"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionUnit="FullRow"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                  AutoGenerateColumns="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.CellStyle>
              <Style TargetType="{x:Type DataGridCell}">
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                      <Grid Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                      </Grid>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Selected" >
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" MinWidth="180" />

              <DataGridTextColumn Header="DIS Value" Binding="{Binding DisValue, UpdateSourceTrigger=PropertyChanged}" MinWidth="100" />

              <DataGridTemplateColumn Header="Valid?" Width="Auto">
                <DataGridTemplateColumn.CellTemplate >
                  <DataTemplate>
                    <Grid>
                      <Border Background="Black" Opacity=".15" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" />
                      <Image Source="{Binding UsesSisoName, Converter={resourcesConverters:HasTickConverter}}" Opacity="1" Height="18 "/>
                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="Suggestions (options, # num options, apply)" Width="Auto">
                <DataGridTemplateColumn.CellTemplate >
                  <DataTemplate>
                    <Grid Width="400">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="150" />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>

                      <Grid Width="Auto">
                        <Grid.Style>
                          <Style TargetType="{x:Type Grid}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="false">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="true">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Grid.Style>
                        <ProgressBar Height="17" Background="SlateGray">
                          <ProgressBar.Style>
                            <Style TargetType="{x:Type ProgressBar}">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="false">
                                  <Setter Property="IsIndeterminate" Value="True" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="true">
                                  <Setter Property="IsIndeterminate" Value="False" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Background="Transparent" FontSize="9" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="Working..." />
                      </Grid>

                      <ComboBox ItemsSource="{Binding SortedBestMatchList, UpdateSourceTrigger=PropertyChanged}"
										          SelectedValue="{Binding SelectedSuggestion, UpdateSourceTrigger=PropertyChanged}" Width="Auto" Height="20">
                        <ComboBox.Style>
                          <Style TargetType="{x:Type ComboBox}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="true">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding HaveLoadedSuggestions}" Value="false">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock>
                            <Run Text="{Binding Description, Mode=OneWay}" />
                            <Run Text=" (" />
                            <Run Text="{Binding FullDisValue, Mode=OneWay}"/>
                            <Run Text=")" />
                            </TextBlock>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                          <Style TargetType="{x:Type ComboBoxItem}">
                            <Setter Property="Margin" Value="1" />
                            <Setter Property="Template">
                              <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                  <TextBlock>
                                  <Run Text="{Binding Description, Mode=OneWay}" />
                                  <Run Text=" (" />
                                  <Run Text="{Binding FullDisValue, Mode=OneWay}"/>
                                  <Run Text=")" />
                                  </TextBlock>
                                </ControlTemplate>
                              </Setter.Value>
                            </Setter>
                          </Style>
                        </ComboBox.ItemContainerStyle>
                      </ComboBox>

                      <Label Grid.Column="1" Content="{Binding SortedBestMatchList.Count}" ContentStringFormat="({0})" VerticalAlignment="Center" Width="40" />

                      <Grid Grid.Column="2" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,3,0" Width="Auto" >
                        <Button Content="Apply" Width="60"
                                Command="{Binding Path=DataContext.ApplySuggestedNameCommand, Source={x:Reference frameWorkElementProxy2}}"
                                CommandParameter="{Binding }" 
                                ToolTip="Apply the suggested name" />
                      </Grid>

                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="# References" Width="Auto">
                <DataGridTemplateColumn.CellTemplate >
                  <DataTemplate>
                    <Grid Width="80">
                      <Grid Width="Auto">
                        <Grid.Style>
                          <Style TargetType="{x:Type Grid}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsLoadingReferences}" Value="true">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsLoadingReferences}" Value="false">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Grid.Style>
                        <ProgressBar Height="17" Background="SlateGray">
                          <ProgressBar.Style>
                            <Style TargetType="{x:Type ProgressBar}">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingReferences}" Value="true">
                                  <Setter Property="IsIndeterminate" Value="True" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsLoadingReferences}" Value="false">
                                  <Setter Property="IsIndeterminate" Value="False" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Background="Transparent" FontSize="9" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="{Binding DataLibReferences.Count, UpdateSourceTrigger=PropertyChanged, StringFormat='Working... {0}'}" />
                      </Grid>
                      <TextBlock>
                        <TextBlock.Style>
                          <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsLoadingReferences}" Value="true">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding IsLoadingReferences}" Value="false" />
                                  <Condition Binding="{Binding HaveLoadedReferences}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Setter Property="Text" Value="?" />
                                </MultiDataTrigger.Setters>
                              </MultiDataTrigger>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding IsLoadingReferences}" Value="false" />
                                  <Condition Binding="{Binding HaveLoadedReferences}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                  <Setter Property="Visibility" Value="Visible" />
                                  <Setter Property="Text" Value="{Binding DataLibReferences.Count, UpdateSourceTrigger=PropertyChanged}" />
                                </MultiDataTrigger.Setters>
                              </MultiDataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="SISO Tool">
                <DataGridTemplateColumn.CellTemplate >
                  <DataTemplate>
                    <Grid Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0" >
                      <Button Command="{Binding Path=DataContext.ShowDisSisoMappingsDLECommand, Source={x:Reference frameWorkElementProxy2}}" CommandParameter="{Binding }" Width="70"
                              ToolTip="Sets the name of the item using the SISO-REF-010 Standard">
                        <Button.Style>
                          <Style TargetType="{x:Type Button}">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding UsesSisoName}" Value="true">
                                <Setter Property="Content" Value="SISO Edit.." />
                                <Setter Property="Background"  Value="LightGray " />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding UsesSisoName}" Value="false">
                                <Setter Property="Content" Value="SISO Edit.." />
                                <Setter Property="Background"  Value="LightGreen" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Button.Style>
                      </Button>
                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTextColumn Header="Type (Config Name)" Binding="{Binding OtherInfo, UpdateSourceTrigger=PropertyChanged}" />

            </DataGrid.Columns>

            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding RecordType}" Value="Missile">
                    <Setter Property="Background" Value="LightCoral"/>
                    <Setter Property="Foreground" Value="White"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding RecordType}" Value="Platform">
                    <Setter Property="Background" Value="LightBlue"/>
                    <Setter Property="Foreground" Value="Black"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding RecordType}" Value="System">
                    <Setter Property="Background" Value="LightYellow"/>
                    <Setter Property="Foreground" Value="Black"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>

            <!-- Behaviours let you augment a control with some more code behind -->
            <i:Interaction.Behaviors>
              <aux:GroupSortAndFilterBehavior x:Name="_groupSortFilterBehavior"
                                               SortDescriptions="{Binding SortDescriptions}"
                                               GroupDescriptions="{Binding GroupDescriptions}"
                                               Filter="{Binding Filter}" />
            </i:Interaction.Behaviors>

            <DataGrid.GroupStyle>
              <!-- Style for groups at top level. -->
              <GroupStyle ContainerStyle="{StaticResource ResourceKey=TopLevelStyle}"/>
              <!-- Style for groups under the top level. -->
              <GroupStyle HeaderTemplate="{StaticResource ResourceKey=LowerLevelStyle}"/>
            </DataGrid.GroupStyle>
          </DataGrid>
        </Grid>
      </GroupBox>

      <!-- Selected DLE Item Commands -->
      <UniformGrid Grid.Row="1" Height="35" Rows="1">
        <Button Content="Apply All Selections" Margin="5" Command="{Binding ApplyAllSelectedItemsCommand}" />
        <Button Content="Revert All Selections" Margin="5" Command="{Binding RevertAllSelectedItemsCommand}" />
        <Button Content="Clear Selections" Margin="5" Command="{Binding ClearSelectionsCommand}" />
      </UniformGrid>
    </Grid>

    <!-- Grid Splitter -->
    <GridSplitter Grid.Column="1" Background="LightGray" Width="5"
                  HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True"/>

    <!-- The Right Panel showing grouping, sorting, filtering and selected item details -->

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Header -->

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- Sorting and Filtering -->

        <GroupBox Header="Sorting and Filtering" Margin="3" Padding="0,1,0,0">

          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
              <ColumnDefinition />
              <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- List of Group Descriptions -->

            <GroupBox Header="Group Descriptions" Margin="2">
              <ListView ItemsSource="{Binding GroupDescriptionOptions}" Margin="1">
                <i:Interaction.Behaviors>
                  <aux:ListViewDragDropReorderBehavior/>
                </i:Interaction.Behaviors>
                <ListView.View>
                  <GridView>
                    <GridViewColumn Header="Active">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <CheckBox IsChecked="{Binding IsActive}"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Property" DisplayMemberBinding="{Binding PropertyName}"/>
                  </GridView>
                </ListView.View>
              </ListView>
            </GroupBox>

            <!-- Completed Filter Toggle -->

            <CheckBox Grid.Row="1" IsChecked="{Binding HasInValidNameFiltering}" Margin="3" HorizontalAlignment="Right"
                    Content="Remove SISO Validated Items" VerticalContentAlignment="Center"/>

            <!-- List of Sort Descriptions -->

            <GroupBox Grid.Column="1" Header="Sort Descriptions" Margin="2" Grid.RowSpan="2">
              <ListView ItemsSource="{Binding SortDescriptionOptions}" Margin="1">
                <i:Interaction.Behaviors>
                  <aux:ListViewDragDropReorderBehavior/>
                </i:Interaction.Behaviors>
                <ListView.View>
                  <GridView>
                    <GridViewColumn Header="Active">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <CheckBox IsChecked="{Binding IsActive}"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="Property" DisplayMemberBinding="{Binding PropertyName}"/>

                    <GridViewColumn Header="Ascending">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <CheckBox IsChecked="{Binding Ascending}"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Descending">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <CheckBox IsChecked="{Binding Descending}"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                  </GridView>
                </ListView.View>
              </ListView>
            </GroupBox>

          </Grid>

        </GroupBox>

        <!-- View Options -->
        <GroupBox Grid.Column="1" Header="Options" Margin="3">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <CheckBox Content="Rename Matching Files to New Name" Margin="3"
                  HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                  IsChecked="{Binding DataLibraryEditorSettings.NamingToolOptions.RenameFilesWithName}"
                  ToolTip="This will also update any filename matching the DLE item when it's name is changed" />

            <CheckBox Grid.Row="1" Content="Lazy Load References" Margin="3"
                  HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                  IsChecked="{Binding DataLibraryEditorSettings.NamingToolOptions.LazyLoadReferences}"
                  ToolTip="When on, references are loaded when the user is viewing the data library item"/>

            <Label Grid.Row="2" Content="(All References Have Been Loaded)" FontWeight="SemiBold"
                   HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                   Visibility="{Binding AllReferencesLoaded, Converter={uiConverters:BoolToVisibilityConverter}}" />

            <Button Grid.Row="3" Command="{Binding LoadAllReferencesCommand}" Height="20" Margin="3">
              <Button.Style>
                <Style TargetType="{x:Type Button}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Path=IsLoadingReferences}" Value="true">
                      <Setter Property="Content" Value="Cancel" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Path=IsLoadingReferences}" Value="false">
                      <Setter Property="Content" Value="Load All References" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
          </Grid>
        </GroupBox>
      </Grid>


      <!-- User Locations -->

      <GroupBox Grid.Row="1" Margin="3" Padding="0,3,0,0">
        <GroupBox.Header>
          <Run Text="{Binding ReferencePathCollection.Count, StringFormat='Search Locations [{0}]', FallbackValue='Search Locations', Mode=OneWay}" />
        </GroupBox.Header>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <ListBox Grid.ColumnSpan="3" MinHeight="10" Margin="1"
                     ItemsSource="{Binding ReferencePathCollection.CollectionView}"
                     Visibility="{Binding DataLibraryEditorSettings.NamingToolOptions.ShowSearchLocations, Converter={uiConverters:BoolToVisibilityConverter}}"/>

          <ListView Grid.Row="1" Grid.ColumnSpan="3" MaxHeight="150" MinHeight="50" Margin="1" SelectionMode="Single"
                    ItemsSource="{Binding UserReferenceLocations}"
                    SelectedItem="{Binding SelectedUserLocation}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Path Type">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate >
                      <ComboBox ItemsSource="{sf:EnumToItemsSource {x:Type dsData:EReferencePathType}}"
                                  SelectedItem="{Binding ReferencePathType}" Width="180" Height="20">
                        <ComboBox.Resources>
                          <Style TargetType="{x:Type ComboBoxItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="MinWidth" Value="200" />
                          </Style>
                        </ComboBox.Resources>
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Path=., Converter={sf:EnumDescriptionBindingConverter}}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                          <Style TargetType="ComboBoxItem">
                            <Setter Property="Content" Value="{Binding Converter={sf:EnumDescriptionBindingConverter}}" />
                          </Style>
                        </ComboBox.ItemContainerStyle>
                      </ComboBox>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>

                <GridViewColumn Header="Location">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate >
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding Path=Location}" VerticalAlignment="Center" HorizontalAlignment="Stretch" MinWidth="600" Height="20" VerticalContentAlignment="Center"/>

                        <Button Grid.Column="1" Margin="1,0" Content=" ... " HorizontalAlignment="Center"
                                  Command="{Binding Path=DataContext.SetUserLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                  ToolTip="Set filename.." />
                      </Grid>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>

                <GridViewColumn Header="" DisplayMemberBinding="{Binding Path=Location, Converter={converters:PathValidatorConverter}}" />

              </GridView>
            </ListView.View>
          </ListView>

          <FrameworkElement x:Name="frameWorkElementProxyLocations" Visibility="Collapsed"/>

          <StackPanel Grid.Row="2" Margin="0,5,3,0" Orientation="Horizontal">
            <TextBlock Text="Static Search Locations:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0" />
            <CheckBox IsChecked="{Binding DataLibraryEditorSettings.NamingToolOptions.ShowSearchLocations}" Content="Show" VerticalContentAlignment="Center"  Margin="5,0"/>

            <!-- Display a list of reference path used in reference data collection -->
            <Grid Margin="10,0" Visibility="{Binding DataLibraryEditorSettings.NamingToolOptions.ShowSearchLocations, Converter={sf:InverseBoolToVisibilityConverter}}">
              <ToggleButton IsChecked="{Binding ShowReferencePathCollections}" Content="  Display List..  " IsEnabled="{Binding ElementName=goToViewBtn, Path=IsEnabled}"/>
              <Popup Placement="Bottom" AllowsTransparency="True" HorizontalOffset="0" IsOpen="{Binding ShowReferencePathCollections, Mode=OneWay}">
                <Border Opacity="1" Background="Wheat" BorderBrush="DarkGray" BorderThickness="1">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Reference path list -->
                    <Border BorderBrush="Tan" Grid.Row="0" BorderThickness="1" Margin="2">
                      <ListBox ItemsSource="{Binding ReferencePathCollection.CollectionView}" MinHeight="15"/>
                    </Border>

                    <!-- Hide button -->
                    <ToggleButton Grid.Row="2" IsChecked="{Binding ShowReferencePathCollections}" HorizontalAlignment="Right" Width="80" Height="20" Margin="0,1,3,2">Hide</ToggleButton>
                  </Grid>
                </Border>
              </Popup>
            </Grid>
          </StackPanel>

          <Button Grid.Row="2" Grid.Column="1" Content="+" Width="30" Margin="3,5,3,0"
                        Command="{Binding AddUserLocationCommand}"/>
          <Button Grid.Row="2" Grid.Column="2" Content="-" Width="30" Margin="3,5,3,0"
                        Command="{Binding RemoveUserLocationCommand}"/>

        </Grid>
      </GroupBox>

      <!-- Selected Item Details -->

      <GroupBox Grid.Row="2" Header="Selected Item Details and References" Margin="3" Padding="0,3,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Buttons -->
          <StackPanel Orientation="Horizontal" Grid.Row="0" Height="22">
            <TextBlock Grid.Row="0" Text="{Binding Path=SelectedItemNamingRecord.Description}" FontWeight="Bold" Margin="5,3" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Text="No Item Selected" FontWeight="Bold" Margin="1,3" VerticalAlignment="Center"
                       Visibility="{Binding SelectedItemNamingRecord, Converter={uiConverters:InverseObjectTypeToVisibilityConverter}}" />

            <Button Content="Open Editor View" Margin="5,1" Width="120" Command="{Binding OpenSelectedItemCommand}" x:Name="goToViewBtn" />

            <Button Content="Load References" Margin="5,1" Width="120" Command="{Binding LoadItemReferencesCommand}"/>
          </StackPanel>

          <!-- Legacy Identity -->
          <GroupBox Grid.Row="1" Header="Legacy Identity" Margin="0,5" Padding="5,5,5,0">
            <UniformGrid Rows="1">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Name: " FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedItemNamingRecord.DbObject.LegacyIdentity.Name, FallbackValue='None'}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Dis Value: " FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedItemNamingRecord.DbObject.LegacyIdentity.DisID, FallbackValue='None'}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="MIL Symbol: " FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedItemNamingRecord.DbObject.LegacyIdentity.MilSymbol, FallbackValue='None'}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Entity Type: " FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedItemNamingRecord.DbObject.LegacyIdentity.EntityType, FallbackValue='None'}" />
              </StackPanel>
              <Button Content="Revert to Original" Command="{Binding RevertIdentityCommand}"/>
            </UniformGrid>
          </GroupBox>

          <!-- Data Library Item Reference Collection -->
          <GroupBox Grid.Row="2" Margin="0,3">
            <GroupBox.Header>
              <Run Text="{Binding SelectedItemNamingRecord.DataLibReferences.Count, StringFormat='Data Library References [{0}]', FallbackValue='Data Library References', Mode=OneWay}" />
            </GroupBox.Header>

            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <FrameworkElement x:Name="frameWorkElementProxy" Visibility="Collapsed"/>

              <Grid Margin="1" Visibility="{Binding SelectedItemNamingRecord, Converter={uiConverters:ObjectTypeToVisibilityConverter}}">
                <ProgressBar Height="15">
                  <ProgressBar.Style>
                    <Style TargetType="{x:Type ProgressBar}">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedItemNamingRecord.IsLoadingReferences}" Value="false">
                          <Setter Property="IsIndeterminate" Value="false" />
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedItemNamingRecord.IsLoadingReferences}" Value="true">
                          <Setter Property="IsIndeterminate" Value="true" />
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </ProgressBar.Style>
                </ProgressBar>
                <Label Background="Transparent" FontSize="9" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Content="Collecting file references.."
                       Visibility="{Binding SelectedItemNamingRecord.IsLoadingReferences, Converter={uiConverters:BoolToVisibilityConverter}}"/>
              </Grid>

              <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedItemNamingRecord.DataLibReferences.CollectionView}"
                    AutoGenerateColumns="False" MinHeight="50"
                    Margin="1,5,1,1"
                    CanUserAddRows="False" IsReadOnly="True"
                    VirtualizingPanel.IsVirtualizing="True"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.CellStyle>
                  <Style TargetType="{x:Type DataGridCell}">
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                          <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                          </Grid>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                  <DataGridTextColumn Header="Path Type" Binding="{Binding ReferencePathType, Converter={sf:EnumDescriptionBindingConverter}}"
                                        Visibility="{Binding DataContext.ShowReferencePathTypeColumn,
                                                      Source={x:Reference frameWorkElementProxy},
                                                      Converter={uiConverters:BoolToVisibilityConverter}}"/>

                  <DataGridTextColumn Header="Search Type" Binding="{Binding ReferenceSearchType, Converter={sf:EnumDescriptionBindingConverter}}"
                                        Visibility="{Binding DataContext.ShowReferenceSearchTypeColumn,
                                                      Source={x:Reference frameWorkElementProxy},
                                                      Converter={uiConverters:BoolToVisibilityConverter}}"/>

                  <DataGridTextColumn Header="Path" Binding="{Binding FilePath}"
                                        Visibility="{Binding DataContext.DataLibraryEditorSettings.NamingToolOptions.TrimUserSearchLocations,
                                                      Source={x:Reference frameWorkElementProxy},
                                                      Converter={sf:InverseBoolToVisibilityConverter}}"/>

                  <DataGridTextColumn Header="Path" Binding="{Binding ShortenedPath}"
                                        Visibility="{Binding DataContext.DataLibraryEditorSettings.NamingToolOptions.TrimUserSearchLocations,
                                                      Source={x:Reference frameWorkElementProxy},
                                                      Converter={uiConverters:BoolToVisibilityConverter}}"/>

                  <DataGridTextColumn Header="Details" Binding="{Binding Details}"
                                        Visibility="{Binding DataContext.ShowReferenceDetailsColumn,
                                                      Source={x:Reference frameWorkElementProxy},
                                                      Converter={uiConverters:BoolToVisibilityConverter}}"/>

                  <DataGridTemplateColumn Header="Open">
                    <DataGridTemplateColumn.CellTemplate >
                      <DataTemplate>
                        <Button Command="{Binding Path=DataContext.FlewsUiService.OpenFileCommand, Source={x:Reference frameWorkElementProxy}}" CommandParameter="{Binding FilePath}"
                                  ToolTip="Open the file for viewing.." Height="15" Margin="1" Content="..."/>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>

              <Grid Grid.Row="2" >
                <Grid.ColumnDefinitions>
                  <ColumnDefinition />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <GroupBox  Header="Column Display Options" Margin="1,3,1,1">
                  <StackPanel Orientation="Horizontal" Margin="1,3,1,0" HorizontalAlignment="Right">
                    <CheckBox Content="Path Type" IsChecked="{Binding ShowReferencePathTypeColumn}"
                          HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="3,1" />
                    <CheckBox Content="Search Type" IsChecked="{Binding ShowReferenceSearchTypeColumn}"
                          HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="5,1" />
                    <CheckBox Content="Trim Project Home" IsChecked="{Binding DataLibraryEditorSettings.NamingToolOptions.TrimUserSearchLocations}"
                          HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="3,1" />
                    <CheckBox Content="Reference Details" IsChecked="{Binding ShowReferenceDetailsColumn}"
                          HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="5,1" />
                  </StackPanel>
                </GroupBox>
                
                <Button Grid.Column="1" Command="{Binding CloseCommand}" Content="Close" IsCancel="True" Margin="5,2,0,0"
                        Height="40" Width="300" />
              </Grid>
            </Grid>
          </GroupBox>
        </Grid>
      </GroupBox>

    </Grid>
  </Grid>

</UserControl>
