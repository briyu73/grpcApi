<UserControl x:Class="FlewsApp.Modules.DataSource.UI.Views.DataSourceManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:sf="http://swordfish.com.au/WPF/1.0"
             xmlns:dataSource="clr-namespace:FlewsApp.Modules.DataSource;assembly=FlewsApp.Modules.DataSource"
             xmlns:dataSourceSettings="clr-namespace:FlewsApp.Modules.DataSource.Data.Settings;assembly=FlewsApp.Modules.DataSource"
             xmlns:local="clr-namespace:FlewsApp.Modules.DataSource.UI.Views"
             MinWidth="400" MinHeight="400" MaxHeight="800">

  <UserControl.Resources>
    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Margin" Value="2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <DataTemplate x:Key="SourceHeader">
      <StackPanel Orientation="Horizontal">

        <TextBlock>
          <TextBlock.Text>
            <MultiBinding StringFormat="{}{0} ({1})">
              <Binding Path="SourceName" />
              <Binding Path="SourceType" Converter="{sf:EnumDescriptionBindingConverter}" />
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="CommonOperations">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" DockPanel.Dock="Left" Text="Enabled: " VerticalAlignment="Center" />
        <CheckBox  Grid.Column="1" DockPanel.Dock="Left" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="2" >
          <i:Interaction.Triggers>
            <i:EventTrigger EventName="Checked">
              <i:InvokeCommandAction Command="{Binding ElementName=SourceListView, Path=DataContext.UnTickOtherSettingsBoxesCommand}" CommandParameter="{Binding}"/>
            </i:EventTrigger>
          </i:Interaction.Triggers>
        </CheckBox>

        <Button Grid.Column="2" HorizontalAlignment="Right" Content="Remove" Margin="2" Padding="2"
                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DataSourceManagerView}}, Path=DataContext.RemoveSourceCommand}"
                CommandParameter="{Binding}" />

      </Grid>
    </DataTemplate>

  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- The list that shows all available data sources -->
    <DockPanel Grid.Row="0" LastChildFill="True" Visibility="{Binding IsEditingSource, Converter={sf:InverseVisibilityConverter}}">

      <Grid DockPanel.Dock="Top" Grid.Row="0" IsEnabled="{Binding IsWorking, Converter={sf:InverseBoolConverter}}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Content="Apply" Command="{Binding ApplyChangesCommand}" IsEnabled="{Binding HasUnappliedChanges}" Margin="2" />
        <Button Grid.Column="1" Content="Modify" Margin="2" Padding="2" Command="{Binding ModifySourceCommand}"/>
        <Button Grid.Column="2" Content="New Source" Command="{Binding NewSourceCommand}" Margin="2" />
      </Grid>

      <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" MinHeight="20" Visibility="{Binding IsWorking, Converter={sf:VisibilityConverter}}" />

      <!-- Display only view of the avaiable data sources -->
      <ListView x:Name="SourceListView" DockPanel.Dock="Top" Grid.IsSharedSizeScope="True" HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding Settings.Sources.CollectionView}" 
                SelectedValue="{Binding SelectedSource}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectionMode="Single">
        <ListView.Resources>

          <DataTemplate DataType="{x:Type dataSourceSettings:SqlDataSourceSettings}">
            <GroupBox>
              <GroupBox.Header>
                <UserControl Content="{Binding}" ContentTemplate="{StaticResource SourceHeader}" />
              </GroupBox.Header>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UserControl Grid.Row="0" Grid.ColumnSpan="100" Content="{Binding}" ContentTemplate="{StaticResource CommonOperations}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server: " />
                <TextBlock Grid.Row="1" Grid.Column="1">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}:{1}">
                      <Binding Path="ServerHost"/>
                      <Binding Path="ServerPort"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Database: " />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabaseName}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="User: " />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UserName}" />

              </Grid>
            </GroupBox>
          </DataTemplate>

          <DataTemplate DataType="{x:Type dataSourceSettings:FileDataSourceSettings}">
            <GroupBox>
              <GroupBox.Header>
                <UserControl Content="{Binding}" ContentTemplate="{StaticResource SourceHeader}" />
              </GroupBox.Header>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UserControl Grid.Row="0" Grid.ColumnSpan="100" Content="{Binding}" ContentTemplate="{StaticResource CommonOperations}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Directory: " VerticalAlignment="Center" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Directory}" />
              </Grid>
            </GroupBox>
          </DataTemplate>

          <DataTemplate DataType="{x:Type dataSourceSettings:MemoryDataSourceSettings}">
            <GroupBox>
              <GroupBox.Header>
                <UserControl Content="{Binding}" ContentTemplate="{StaticResource SourceHeader}" />
              </GroupBox.Header>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UserControl Grid.Row="0" Grid.ColumnSpan="100" Content="{Binding}" ContentTemplate="{StaticResource CommonOperations}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Shared Store Id: " VerticalAlignment="Center" Margin="2" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StoreId}" MinWidth="50" VerticalAlignment="Center" Margin="2" />
              </Grid>
            </GroupBox>
          </DataTemplate>

          <DataTemplate DataType="{x:Type dataSourceSettings:LiteDbDataSourceSettings}">
            <GroupBox>
              <GroupBox.Header>
                <UserControl Content="{Binding}" ContentTemplate="{StaticResource SourceHeader}" />
              </GroupBox.Header>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <UserControl Grid.Row="0" Grid.ColumnSpan="100" Content="{Binding}" ContentTemplate="{StaticResource CommonOperations}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Filename: " VerticalAlignment="Center" Margin="2" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Filename}" MinWidth="50" VerticalAlignment="Center" Margin="2" />
              </Grid>
            </GroupBox>
          </DataTemplate>

          <DataTemplate DataType="{x:Type dataSourceSettings:DataSourceSettings}">
            <GroupBox>
              <GroupBox.Header>
                <UserControl Content="{Binding}" ContentTemplate="{StaticResource SourceHeader}" />
              </GroupBox.Header>

              <UserControl Content="{Binding}" ContentTemplate="{StaticResource CommonOperations}" />
            </GroupBox>
          </DataTemplate>
        </ListView.Resources>
      </ListView>

    </DockPanel>

    <!-- Panel that is shown when adding a new data source -->
    <Grid Grid.Row="0" Visibility="{Binding IsEditingSource, Converter={sf:VisibilityConverter}}" IsEnabled="{Binding IsWorking, Converter={sf:InverseBoolConverter}}"
          Background="Bisque" Grid.IsSharedSizeScope="True">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1000"
            IsEnabled="{Binding IsWorking, Converter={sf:InverseBoolConverter}}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Content="{Binding CancelSourceButtonText}" Command="{Binding CancelSourceCommand}" Margin="2" />
        <Button Grid.Column="2" Content="Save" Command="{Binding SaveSourceCommand}" Margin="2" Visibility="{Binding IsNewSource, Converter={sf:VisibilityConverter}}" />
      </Grid>

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Type: " VerticalAlignment="Center" Margin="2" />
      <sf:ComboBoxNoReset Grid.Row="1" Grid.Column="1" SelectedValue="{Binding SourceType}"
                ItemsSource="{sf:EnumToItemsSource {x:Type dataSource:EDataSourceType}}" Margin="2"
                IsEnabled="{Binding IsNewSource}"/>

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Name: " VerticalAlignment="Center" Margin="2" />
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewSourceSettings.SourceName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2" />

      <UserControl Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="1000"
                   Content="{Binding NewSourceSettings}">
        <UserControl.Resources>

          <DataTemplate DataType="{x:Type dataSourceSettings:SqlDataSourceSettings}">
            <!-- SQL Data Source -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Server / Port: " VerticalAlignment="Center" Margin="2" />
              <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                <TextBox Text="{Binding ServerHost}" MinWidth="120" Margin="2"/>
                <TextBlock Text=":" VerticalAlignment="Center" />
                <TextBox Text="{Binding ServerPort}" MinWidth="80" Margin="2"/>
              </StackPanel>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Database: " VerticalAlignment="Center" Margin="2" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DatabaseName}" Margin="2" />

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Username: " VerticalAlignment="Center" Margin="2" />
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UserName}" Margin="2" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Password: " VerticalAlignment="Center" Margin="2" />
              <PasswordBox Grid.Row="4" Grid.Column="1" Margin="2" PasswordChanged="SourcePasswordBox_PasswordChanged" />

              <Button Grid.Row="5" Grid.Column="1" Content="Test" Margin="2"
                Command="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.TestUserConnectionCommand}" />

              <Expander Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Header="Admin Functions"
                        IsExpanded="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.ExpandAdminFunctions}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Admin Name: " VerticalAlignment="Center" Margin="2" />
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.AdminName}" Margin="2" />

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Admin Password: " VerticalAlignment="Center" Margin="2" />
                  <PasswordBox Grid.Row="1" Grid.Column="1" PasswordChanged="AdminPasswordBox_PasswordChanged" Margin="2" />

                  <Button Grid.Row="2" Grid.Column="1" Content="Create User" Margin="2"
                          Command="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.CreateUserCommand}" />
                  <Button Grid.Row="3" Grid.Column="1" Content="Create DB" Margin="2"
                          Command="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.CreateDatabaseCommand}"/>
                </Grid>
              </Expander>
            </Grid>
          </DataTemplate>


          <DataTemplate DataType="{x:Type dataSourceSettings:MemoryDataSourceSettings}">
            <!-- Memory Data Source -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Shared Store Id: " VerticalAlignment="Center" Margin="2" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StoreId, UpdateSourceTrigger=PropertyChanged}" MinWidth="50" VerticalAlignment="Center" Margin="2" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Preload Default Data" VerticalAlignment="Center" Margin="2" />
              <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding PreloadDefault}" VerticalAlignment="Center"/>

            </Grid>
          </DataTemplate>


          <DataTemplate DataType="{x:Type dataSourceSettings:LiteDbDataSourceSettings}">
            <!-- LiteDB Data Source -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Filename: " VerticalAlignment="Center" Margin="2" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Filename, UpdateSourceTrigger=PropertyChanged}" MinWidth="50" VerticalAlignment="Center" Margin="2" />
              <Button Grid.Row="0" Grid.Column="2" Content="..." MinWidth="80" Margin="2" 
                      Command="{Binding RelativeSource={RelativeSource AncestorType=local:DataSourceManagerView}, Path=DataContext.SelectLiteDbFileCommand}" />
            </Grid>
          </DataTemplate>
        </UserControl.Resources>
      </UserControl>
      <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="1000">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Col1" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="2">
                   <Run Text="Resolve base object"></Run>
          <LineBreak></LineBreak>
          <Run Text="linking issues by: "></Run>
        </TextBlock>
        <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="50" VerticalAlignment="Center" Margin="2"
                  ItemsSource="{sf:EnumToItemsSource {x:Type dataSourceSettings:ResolveMissingBaseObjectOptions}}"
                  SelectedItem="{Binding NewSourceSettings.ResolveMissingBaseObjectOption}">
        </ComboBox>
      </Grid>
      <Button Grid.Row="1000" Grid.Column="1" Content="RESET DATA" Margin="2" Command="{Binding ResetDataSourceCommand}"
              Visibility="{Binding EnableDataSourceResetting, Converter={sf:VisibilityConverter}}" />
    </Grid>
  </Grid>
</UserControl>
