<UserControl x:Class="BAM.Modules.DataAccess.UI.Views.DatabaseViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BAM.Modules.DataAccess.UI.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             
             d:DesignHeight="1000" d:DesignWidth="1500"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">

  <prism:Dialog.WindowStyle>
    <Style TargetType="Window" BasedOn="{StaticResource MaterialDesignWindow}">
      <Setter Property="Width" Value="1250"/>
      <Setter Property="Height" Value="1000"/>
      <Setter Property="SizeToContent" Value="Manual"/>
      <Setter Property="ResizeMode" Value="CanResize"/>
    </Style>
  </prism:Dialog.WindowStyle>
  
  <UserControl.Resources>
    <!-- DataTemplate for primitive types (string, int, bool, etc.) -->
    <DataTemplate x:Key="PrimitiveTemplate">
      <TextBlock Text="{Binding}"/>
    </DataTemplate>

    <!-- DataTemplate for DateTime -->
    <DataTemplate x:Key="DateTimeTemplate">
      <TextBlock Text="{Binding StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" FontStyle="Italic"/>
    </DataTemplate>

    <!-- DataTemplate for Guid -->
    <DataTemplate x:Key="GuidTemplate">
      <TextBlock Text="{Binding}" FontFamily="Consolas"/>
    </DataTemplate>

    <!-- DataTemplate for null values -->
    <DataTemplate x:Key="NullTemplate">
      <TextBlock Text="[NULL]" FontStyle="Italic" Foreground="Gray"/>
    </DataTemplate>

    <!-- DataTemplate for complex objects -->
    <DataTemplate x:Key="ComplexObjectTemplate">
      <Border Background="{DynamicResource MaterialDesignShadowBrush}" Padding="2" Margin="2" CornerRadius="3">
        <Expander Header="{Binding TypeName}" IsExpanded="False">
          <ItemsControl ItemsSource="{Binding Properties}" Margin="10,5">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                  <TextBlock Text="{Binding Name}" Style="{DynamicResource MaterialDesignLabelMediumTextBlock}" Width="150"/>
                  <TextBlock Text=": " Style="{DynamicResource MaterialDesignLabelMediumTextBlock}"/>
                  <ContentPresenter Content="{Binding Value}" Margin="5 0"
                                    ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DataTemplateSelector}"/>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Expander>
      </Border>
    </DataTemplate>

    <!-- DataTemplate for collections -->
    <DataTemplate x:Key="CollectionTemplate">
      <Border Background="{DynamicResource MaterialDesignShadowBrush}" Padding="2" Margin="2" CornerRadius="3">
        <Expander Header="{Binding Header}" IsExpanded="False">
          <ItemsControl ItemsSource="{Binding Items}" Margin="10,5">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <ContentPresenter Content="{Binding}" Margin="0,2"
                                  ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DataTemplateSelector}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Expander>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Padding="10">
      <StackPanel Orientation="Horizontal">
        <Button Content="Load Database" Command="{Binding LoadDatabaseCommand}" 
                Margin="0,0,10,0" IsDefault="True" Width="100" Height="25"/>
        <TextBlock Text="{Binding DatabaseInfo}" VerticalAlignment="Center"
                   d:Text="Database Info here..."/>
      </StackPanel>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1" MinWidth="1250" MinHeight="800">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="250"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left Panel - Entity Types -->
      <Border Grid.Column="0" BorderThickness="0,0,1,0">
        <DockPanel>
          <TextBlock Text="Entity Types" Style="{DynamicResource MaterialDesignTitleMediumTextBlock}" VerticalAlignment="Bottom"
                     Padding="9" Background="{DynamicResource MaterialDesignShadowBrush}" DockPanel.Dock="Top"/>
          <ListBox ItemsSource="{Binding EntityTypes}" 
                   SelectedItem="{Binding SelectedEntityType}"
                   DisplayMemberPath="Name" Padding="5"/>
        </DockPanel>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Gray"/>

      <!-- Right Panel - Entity Data -->
      <Border Grid.Column="2">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Background="{DynamicResource MaterialDesignShadowBrush}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Entities: " Style="{DynamicResource MaterialDesignTitleMediumTextBlock}" VerticalAlignment="Bottom" Margin="5,5,0,5"/>
            <TextBlock Grid.Column="1" Text="{Binding EntityCount, FallbackValue=0}" Style="{DynamicResource MaterialDesignTitleMediumTextBlock}" VerticalAlignment="Bottom" Margin="0,5" />
            <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshEntitiesCommand}" Margin="20,5,5,5" Width="80" />
          </Grid>

          <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                 VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Entities}" Margin="10">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="DarkGray" BorderThickness="1" 
                          Margin="0,5" CornerRadius="5" Padding="10">
                    <ContentPresenter Content="{Binding}"
                                      ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DataTemplateSelector}"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <StatusBar Grid.Row="2">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusMessage}"/>
      </StatusBarItem>
    </StatusBar>
  </Grid>
</UserControl>
