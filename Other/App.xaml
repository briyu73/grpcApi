<prism:PrismApplication x:Class="BAM.Shell.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BAM.Shell.WPF"
             xmlns:prism="http://prismlibrary.com/" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Material Design base themes -->
        <!-- This line required here otherwise Material Design theme dictionary will not be found -->
        <!-- Also important, if you try to merge another dictionary with includes the Material Design
             theme again this will break the light/dark switching functionality -->
        <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Indigo" SecondaryColor="Lime" />

        <ResourceDictionary Source="/BAM.Shell.WPF;component/Resources/BamShellWpfResources.xaml" />
        <ResourceDictionary Source="/BAM.Libraries.WpfLib;component/Dialogs/Resources/DialogResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</prism:PrismApplication>
