<UserControl x:Class="BAM.Shell.WPF.Views.PortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BAM.Shell.WPF.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:wpfLibConverters="clr-namespace:BAM.Libraries.WpfLib.Converters;assembly=BAM.Libraries.WpfLib"
             xmlns:viewModels="clr-namespace:BAM.Shell.WPF.ViewModels"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wpfLibBehaviours="clr-namespace:BAM.Libraries.WpfLib.Behaviours;assembly=BAM.Libraries.WpfLib"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"

             prism:ViewModelLocator.AutoWireViewModel="True"
             KeyboardNavigation.TabNavigation="Contained"
             IsTabStop="False"
             d:Background="{StaticResource MaterialDesignPaper}">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/BAM.Shell.WPF;component/Resources/BamShellWpfResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <!-- Root Grid -->

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="auto" />
    </Grid.ColumnDefinitions>

    <!-- Portfolio Positions Pane -->
    <GroupBox Header="Portfolio Positions" Margin="5">

      <DataGrid ItemsSource="{Binding SelectedPortfolioModel.Positions}"
                    SelectedValue="{Binding SelectedPositionModel}"
                    CanUserAddRows="False" IsReadOnly="True"
                    SelectionUnit="FullRow"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                    EnableRowVirtualization="True"
                    EnableColumnVirtualization="True"
                    AutoGenerateColumns="False"
                    d:Height="500"  d:Width="700"
                    AlternationCount="{Binding Items.Count, RelativeSource={RelativeSource Self}}">

        <!-- Behaviours let you augment a control with some more code behind -->
        <i:Interaction.Behaviors>
          <wpfLibBehaviours:GroupSortAndFilterBehavior x:Name="_groupSortFilterBehavior"
                                               SortDescriptions="{Binding SortDescriptions}"
                                               GroupDescriptions="{Binding GroupDescriptions}"
                                               Filter="{Binding Filter}"/>
        </i:Interaction.Behaviors>

        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
            <Setter Property="IsSelected"
                      Value="{Binding DataContext.ExpandAllPositions, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
            <Setter Property="Height" Value="Auto" />
          </Style>
        </DataGrid.RowStyle>

        <DataGrid.Columns>
          <DataGridTextColumn Header="#" Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, 
                                  Path=(ItemsControl.AlternationIndex), Converter={wpfLibConverters:AddOneConverter}}" Width="Auto" />
          <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="Auto"/>
          <DataGridTextColumn Header="Kind" Binding="{Binding PositionKind}" Width="Auto"/>
          <DataGridTextColumn Header="Type" Binding="{Binding PositionType}" Width="Auto"/>
          <DataGridTextColumn Header="Trades #" Binding="{Binding Trades.Count}" Width="Auto"/>
          <DataGridTextColumn Header="Units Bought" Binding="{Binding BuyUnits, StringFormat=N0}" Width="Auto"/>
          <DataGridTextColumn Header="Buy Costs" Binding="{Binding BuyCosts, StringFormat=C}" Width="Auto"/>
          <DataGridTextColumn Header="Units Sold" Binding="{Binding SellUnits, StringFormat=N0}" Width="Auto"/>
          <DataGridTextColumn Header="Sell Funds" Binding="{Binding SellFunds, StringFormat=C}" Width="Auto"/>
          <DataGridTemplateColumn Header="Valid?" Width="Auto">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Grid>
                  <fa:IconBlock Icon="CheckCircle" FontSize="18"
                              Foreground="ForestGreen"
                              Visibility="{Binding IsValid, Converter={wpfLibConverters:BoolToVisibilityConverter}}"/>

                  <fa:IconBlock Icon="TimesCircle" FontSize="18"
                              Foreground="IndianRed">
                    <fa:IconBlock.Style>
                      <Style TargetType="fa:IconBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsValid}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </fa:IconBlock.Style>
                  </fa:IconBlock>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>

        <DataGrid.RowDetailsTemplate>
          <DataTemplate>
            <DataGrid ItemsSource="{Binding Trades}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Margin="10,4,10,10"
                      CanUserAddRows="False"
                      RowDetailsVisibilityMode="VisibleWhenSelected">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Contract Note" Binding="{Binding ContractNote, FallbackValue='N/A'}" Width="Auto" />
                <DataGridTextColumn Header="Type" Binding="{Binding TradeType}" Width="Auto" />
                <DataGridTextColumn Header="Trade Date" Binding="{Binding TradeDate, StringFormat={}{0:dd/MM/yyyy}}" Width="Auto" />
                <DataGridTextColumn Header="Settlement Date" Binding="{Binding SettlementDate, StringFormat={}{0:dd/MM/yyyy}, FallbackValue='N/A'}" Width="Auto" />
                <DataGridTextColumn Header="Units" Binding="{Binding Units, StringFormat=N0}" Width="Auto" />
                <DataGridTextColumn Header="Average Price" Binding="{Binding AveragePrice.Amount, StringFormat=C}" Width="Auto" />
                <DataGridTextColumn Header="Brokerage" Binding="{Binding BrokerageFee, StringFormat=C}" Width="Auto" />
                <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat=C}" Width="Auto" />
                <DataGridTemplateColumn Header="Valid?" Width="Auto">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Grid>
                        <fa:IconBlock Icon="CheckCircle" FontSize="18" Foreground="ForestGreen"
                                      Visibility="{Binding IsValid, Converter={wpfLibConverters:BoolToVisibilityConverter}}"/>

                        <fa:IconBlock Icon="TimesCircle" FontSize="18" Foreground="IndianRed">
                          <fa:IconBlock.Style>
                            <Style TargetType="fa:IconBlock">
                              <Setter Property="Visibility" Value="Visible"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </fa:IconBlock.Style>
                        </fa:IconBlock>
                      </Grid>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Notes" Width="Auto">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ItemsControl ItemsSource="{Binding NoteEntries}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Margin="1" Padding="4,1" CornerRadius="3">
                              <TextBlock Text="{Binding}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </DataTemplate>
        </DataGrid.RowDetailsTemplate>
      </DataGrid>

    </GroupBox>

    <!-- Right Panel -->

    <Border Grid.Column="1" Padding="16" CornerRadius="12" BorderThickness="1"
            Background="{DynamicResource MaterialDesign.Brush.Paper}"
            BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}">
      <StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
          <materialDesign:PackIcon Kind="ChartLine" Margin="0,0,8,0" Width="25" Height="25" />
          <TextBlock Text="{Binding ViewMessage, StringFormat='Portfolio Details {0}'}" FontWeight="SemiBold" 
                     Style="{DynamicResource MaterialDesignHeadline5TextBlock}" x:Name="header" />
        </StackPanel>

        <Grid>
          <Grid.Style>
            <Style TargetType="Grid">
              <Style.Triggers>
                <DataTrigger Binding="{Binding ShellService.LoadedProfile.SelectedEntity}" Value="{x:Null}">
                  <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>

          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <StackPanel Orientation="Horizontal" Margin="5">
            <Border BorderThickness="4" BorderBrush="{DynamicResource MaterialDesignDivider}" Margin="0 5" Padding="4">
              <UniformGrid Rows="1">
                <Label Content="Type" FontWeight="Bold"/>
                <RadioButton Content="Security" Margin="0,0,5,0" TabIndex="1"
                   IsChecked="{Binding PortfolioType, Converter={wpfLibConverters:EnumBooleanConverter},
                                       ConverterParameter={x:Static viewModels:PortfolioViewModel+EPortfolioType.Security}}"/>
                <RadioButton Content="Property" Margin="5,0" TabIndex="2"
                   IsChecked="{Binding PortfolioType, Converter={wpfLibConverters:EnumBooleanConverter},
                                       ConverterParameter={x:Static viewModels:PortfolioViewModel+EPortfolioType.Property}}"/>
                <RadioButton Content="Manged Fund" Margin="5,0,10,0" TabIndex="3"
                   IsChecked="{Binding PortfolioType, Converter={wpfLibConverters:EnumBooleanConverter},
                                       ConverterParameter={x:Static viewModels:PortfolioViewModel+EPortfolioType.ManagedFund}}"/>
              </UniformGrid>
            </Border>
            <Button Margin="5,0,0,0" Height="35" Command="{Binding AddPortfolioButtonCommand}">
              <fa:IconImage Icon="Plus" Style="{StaticResource fontAwesomeBtnIconStyle}"/>
            </Button>
          </StackPanel>

          <Border Grid.Row="1" Margin="5" BorderThickness="4" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <TabControl Margin="5" 
                      ItemsSource="{Binding ShellService.LoadedProfile.SelectedEntity.Portfolios}" 
                      SelectedItem="{Binding SelectedPortfolioModel}">

              <TabControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </TabControl.ItemTemplate>

              <TabControl.ContentTemplate>
                <DataTemplate>
                  <Grid Margin="0,10" FocusManager.FocusedElement="{Binding ElementName=nameTb}">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Content="Name" Margin="5" FontWeight="Bold"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="5" MinWidth="200" VerticalContentAlignment="Center" TabIndex="1"
                        Text="{Binding Name}" d:Text="Portfolio 1" x:Name="nameTb" />

                    <Label Grid.Row="1" Content="Description" Margin="5" FontWeight="Bold"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5" MinWidth="200" VerticalContentAlignment="Center" TabIndex="2"
                        Text="{Binding Description}" d:Text="Is going to make me rich one day!" />

                    <Label Grid.Row="2" Content="Created" Margin="5" FontWeight="Bold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center" 
                        Text="{Binding CreatedDate, StringFormat='{}{0:dddd, MMMM dd, yyyy}'}" d:Text="April 27, 2024"/>

                  </Grid>
                </DataTemplate>
              </TabControl.ContentTemplate>
            </TabControl>
          </Border>

          <UniformGrid Grid.Row="2" Margin="5">
            <Button Content="Delete"
              Command="{Binding DeletePortfoliCommand}"/>
            <Button Content="Save" Margin="5,0,0,0"
              Command="{Binding SavePortfolioCommand}" IsDefault="True" />
          </UniformGrid>

          <Button Grid.Row="3" Content="Import Trades" Margin="5" Command="{Binding ImportTradesCommand}" />
        </Grid>

  </StackPanel>
  </Border>
  </Grid>

</UserControl>
