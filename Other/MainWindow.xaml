<Window x:Class="BAM.Shell.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BAM.Shell.WPF.Views"
        xmlns:viewModels="clr-namespace:BAM.Shell.WPF.ViewModels"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:wpfLibConverters="clr-namespace:BAM.Libraries.WpfLib.Converters;assembly=BAM.Libraries.WpfLib"
        xmlns:mainModels="clr-namespace:BAM.Modules.DataService.Models.FinanceEDM.Main;assembly=BAM.Modules.DataService"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:wpfLibVm="clr-namespace:BAM.Libraries.WpfLib.Dialogs.ViewModels;assembly=BAM.Libraries.WpfLib"
        xmlns:wpfLibViews="clr-namespace:BAM.Libraries.WpfLib.Dialogs.Views;assembly=BAM.Libraries.WpfLib"
        mc:Ignorable="d"
        
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" 
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        KeyboardNavigation.TabNavigation="None"
        MouseDown="Window_MouseDown"
        UseLayoutRounding="True"
        d:Width="1800" d:Height="1200">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/BAM.Shell.WPF;component/Resources/BamShellWpfResources.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <SolidColorBrush x:Key="controlCloseBtnColor" Color="#FB539B" />
      <SolidColorBrush x:Key="controlMaxBtnColor" Color="#FFC047" />
      <SolidColorBrush x:Key="controlMinBtnColor" Color="#4ADAEC" />
      <SolidColorBrush x:Key="sideBarBtnColor" Color="#0078D4" />
      <SolidColorBrush x:Key="titleBarBackgroundColor" Color="#FF070738" />
      <SolidColorBrush x:Key="sideBarBtnIsCheckedColor" Color="#FB539B" />

      <!-- Control bar button -->
      <Style x:Key="controlButton" TargetType="Button">
        <Setter Property="Width" Value="35" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                  CornerRadius="4">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>

        <Style.Triggers>
          <!-- Button style on hover -->
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Background}" />
            <Setter Property="Foreground" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Menu button icon -->
      <Style x:Key="controlBtnIcon" TargetType="fa:IconImage">
        <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
      </Style>

      <!-- ************************************************************************** -->
      <!-- Side Bar Button Styles -->

      <Style x:Key="SideBarButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="RadioButton">
              <Border Background="{DynamicResource MaterialDesign.Brush.Background}"
                  BorderThickness="4,0,0,0"
                  BorderBrush="{TemplateBinding BorderBrush}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,3,5" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>

        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="BorderBrush" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}" />
          </Trigger>

          <Trigger Property="IsChecked" Value="True">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Foreground" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}" />
            <Setter Property="BorderBrush" Value="{StaticResource sideBarBtnIsCheckedColor}" />
          </Trigger>

        </Style.Triggers>
      </Style>

      <Style x:Key="SideBarSpacerStyle" TargetType="Button">
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border BorderThickness="4,0,0,0"
                  BorderBrush="{TemplateBinding BorderBrush}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,10,3,10" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Side bar button icon style -->
      <Style x:Key="SideBarBtnIconStyle" TargetType="fa:IconImage">
        <Setter Property="Foreground" Value="{Binding Path=Tag, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="Width" Value="45" />
        <Setter Property="Height" Value="45" />
      </Style>

      <!-- Menu button text -->
      <Style x:Key="SideBarBtnTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody1TextBlock}">
        <Setter Property="Foreground" Value="{Binding Path=Tag, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
        <Setter Property="FontWeight" Value="Medium" /> 
      </Style>

      <!-- ************************************************************************** -->
      <!-- Function Bar Items -->

      <!-- Button that look like tab item within the function bar -->
      <Style x:Key="TabItemButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Margin" Value="5,5,5,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Grid>
                <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5,15,0,0"
                            Margin="0,0,0,-1"
                            SnapsToDevicePixels="True">
                  <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"
                            RecognizesAccessKey="True"/>
                </Border>
              </Grid>
              <ControlTemplate.Triggers>

                <!-- ✅ React to the DataContext's IsSelected property -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                  <Setter TargetName="TabBorder" Property="Background" Value="DarkSlateGray"/>
                  <Setter TargetName="TabBorder" Property="BorderBrush" Value="#ACACAC"/>
                  <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0"/>
                  <!-- Push tab slightly upward to simulate the selected TabItem lift -->
                  <Setter TargetName="TabBorder" Property="Margin" Value="0,-1,0,-1"/>
                </DataTrigger>

              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
   
      <!-- DataTemplate for button content -->
      <DataTemplate x:Key="TabItemButtonDataTemplate">
        <TextBlock Text="{Binding Name}"/>
      </DataTemplate>

    </ResourceDictionary>
  </Window.Resources>

  <!-- In order to style the window, we need to set the Window's style AFTER importing Material Design. -->
  <Window.Style>
    <StaticResource ResourceKey="MaterialDesignWindow" />
  </Window.Style>

  <materialDesign:DialogHost Identifier="RootDialog">

    <materialDesign:DialogHost.Resources>
      <DataTemplate DataType="{x:Type wpfLibVm:MessageDialogViewModel}">
        <wpfLibViews:MessageDialog />
      </DataTemplate>

      <DataTemplate DataType="{x:Type wpfLibVm:TextInputDialogViewModel}">
        <wpfLibViews:TextInputDialog />
      </DataTemplate>

      <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <local:SettingsView />
      </DataTemplate>

      <DataTemplate DataType="{x:Type viewModels:DataSourceManager2ViewModel}">
        <local:DataSourceManager2View />
      </DataTemplate>
    </materialDesign:DialogHost.Resources>

    <!-- Main Grid Layout -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- +++++++++++++++++++++++++++++ Window Controls Bar +++++++++++++++++++++++++++ -->
      <!-- Not Used -->
      
      <StackPanel Height="20" Visibility="Collapsed"
                x:Name="panelControlBar"
                Orientation="Horizontal"
                FlowDirection="RightToLeft"
                MouseLeftButtonDown="panelControlBar_MouseLeftButtonDown"
                MouseEnter="panelControlBar_MouseEnter">

        <Button x:Name="btnClose" 
              Style="{StaticResource controlButton}" 
              Tag="{StaticResource controlCloseBtnColor}"
              Click="btnClose_Click">
          <fa:IconImage Icon="Xmark" Style="{StaticResource controlBtnIcon}" />
        </Button>

        <Button x:Name="btnMaximize" 
              Style="{StaticResource controlButton}" 
              Tag="{StaticResource controlMaxBtnColor}"
              Click="btnMaximize_Click">
          <fa:IconImage Icon="Square" Style="{StaticResource controlBtnIcon}" />
        </Button>

        <Button x:Name="btnMinimize" 
              Style="{StaticResource controlButton}" 
              Tag="{StaticResource controlMinBtnColor}"
              Click="btnMinimize_Click">
          <fa:IconImage Icon="WindowMinimize" Width="12" Style="{StaticResource controlBtnIcon}" />
        </Button>

      </StackPanel>

      <!-- ++++++++++++++++++++++++++++ Title Bar +++++++++++++++++++++++++++++++++++++++ -->

      <Border Grid.Row="1" Height="60" 
            Background="{DynamicResource titleBarBackgroundColor}">
        <Grid >
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Logo -->
          <StackPanel Orientation="Horizontal" >
            <Image Source="/Images/china-girl.png" Width="50" RenderTransformOrigin="0.5,0.5" Margin="10 0">
              <Image.RenderTransform>
                <ScaleTransform ScaleX="-1" />
              </Image.RenderTransform>
            </Image>
            <Viewbox Margin="7 8 7 0" HorizontalAlignment="Left" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <TextBlock FontWeight="Medium" FontFamily="{StaticResource LatoBold}" FontSize="22">
                  <Run Text="B" Foreground="{StaticResource wordBlueBrush}" /><Run Text="A" Foreground="{StaticResource wordOrangeBrush}" /><Run Text="M" Foreground="{StaticResource wordRedBrush}" />
                  <Run Text="Wealth" Foreground="{StaticResource wordGreenBrush}" FontSize="14" />
                </TextBlock>
              </StackPanel>
            </Viewbox>
          </StackPanel>

          <Image Grid.Column="1" Source="/Images/SV_Text.png" Width="300"/>

          <!-- Profile Picture -->
          <Ellipse Grid.Column="2" Height="40" Width="35"
                 Stroke="#0078D4"
                 StrokeThickness="2"
                 Margin="10,0,10,0"
                 Visibility="{Binding ShellService.LoadedProfile, Converter={wpfLibConverters:NullToVisibilityConverter}}">
            <Ellipse.Fill>
              <ImageBrush ImageSource="/Images/profile.jpg" />
            </Ellipse.Fill>
          </Ellipse>

          <!-- User Profile Section -->
          <TextBlock Grid.Column="3" Margin="3,0,15,0"
                   Style="{DynamicResource MaterialDesignHeadline4TextBlock}"
                   d:Text="Welcome User"
                   Foreground="White"
                   Text="{Binding ShellService.LoadedProfile.DisplayName}" 
                   VerticalAlignment="Center"/>

          <!-- Login/register button -->
          <Button Grid.Column="4" Height="40" Margin="0,10,10,10" FontSize="20"
                IsDefault="True"
                Command="{Binding ShowLoginViewCommand}" 
                Visibility="{Binding ShellService.LoadedProfile.IsLoggedIn, Converter={wpfLibConverters:InverseBoolToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ShellService.HaveExistingProfiles}" Value="True">
                    <Setter Property="Content" Value="Login" />
                  </DataTrigger>

                  <DataTrigger Binding="{Binding ShellService.HaveExistingProfiles}" Value="False">
                    <Setter Property="Content" Value="Register" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </Border>

      <!-- ++++++++++++++++++++++++++++ Function Bar +++++++++++++++++++++++++++++++++++++++ -->

      <Border Grid.Row="2" Height="42" BorderThickness="0,4,0,4">
        <Border.BorderBrush>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#87CEEB" Offset="0"/>
            <GradientStop Color="#001a66" Offset="1"/>
          </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid>
          <Grid.Resources>
            <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}"/>
            <mainModels:EntityModel x:Key="AddEntityModel" Name="+"/>
          </Grid.Resources>

          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Horizontal Panel with Selectable Buttons -->
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="5,0">
            <StackPanel Orientation="Horizontal">
              <ItemsControl ItemsSource="{Binding ShellService.LoadedProfile.Entities}">

                <d:ItemsControl.Items>
                  <mainModels:EntityModel Name="Entity 1" />
                  <mainModels:EntityModel Name="Entity 2" />
                </d:ItemsControl.Items>

                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Command="{Binding DataContext.SelectEntityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}"
                          ContentTemplate="{StaticResource TabItemButtonDataTemplate}"
                          Content="{Binding}">
                      <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabItemButtonStyle}">
                          <Style.Triggers>
                            <MultiDataTrigger>
                              <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="True" />
                              </MultiDataTrigger.Conditions>
                            </MultiDataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!--<Button MinWidth="60"
                    Style="{StaticResource TabItemButtonStyle}"
                    Command="{Binding DataContext.AddEntityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    DataContext="{StaticResource AddEntityModel}">
              <fa:IconImage Icon="Plus" Style="{StaticResource fontAwesomeBtnIconStyle}"/>
            </Button>-->
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="5,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding ShellService.UserMessage}"
                     Style="{DynamicResource MaterialDesignTitleLargeTextBlock}" 
                     d:Text="Press '+' button to create a new entity"/>
          </ScrollViewer>

          <materialDesign:Card Grid.Column="2" UniformCornerRadius="16" Padding="15 2" VerticalAlignment="Center" Margin="10 3" BorderBrush="Orange" BorderThickness="2" >
            <TextBlock Text="{Binding CurrentDateTime, StringFormat='{}{0:dddd, MMMM dd, yyyy - HH:mm}'}" 
                     Style="{DynamicResource MaterialDesignHeadline6TextBlock}" 
                     FontSize="18" d:Text="April 27, 2024 - 14:30" />
          </materialDesign:Card>
        </Grid>
      </Border>

      <!-- ++++++++++++++++++++++++++++ Document Area +++++++++++++++++++++++++++++++++++++++ -->

      <Grid Grid.Row="3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ++++++++++++++++++++++++++++ SideBar Buttons +++++++++++++++++++++++++++++++++ -->

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="#87CEEB" Offset="0"/>
              <GradientStop Color="#001a66" Offset="1"/>
            </LinearGradientBrush>
          </Grid.Background>

          <RadioButton
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowDashboardViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="Home" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Dashboard" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="1"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowEntityViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="IdCard" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Entity" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="2"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowPortfolioViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="Briefcase" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Portfolio" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="3"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowWatchlistsViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="list" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Watchlist" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="4"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowAccountsViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="BuildingColumns" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Accounts" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="5"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowTransactionsViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="MoneyBillTransfer" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Transactions" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="6"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowBudgetsViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="Calculator" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Budgets" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <!-- space-filler dummy button -->
          <Button Grid.Row="7" IsEnabled="False"
                Style="{StaticResource SideBarSpacerStyle}"/>

          <RadioButton Grid.Row="8" x:Name="toolsRadioButton"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 MouseEnter="ToolsRadioButton_MouseEnter"
                 MouseLeave="ToolsRadioButton_MouseLeave">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="Tools" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Tools" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <!-- Popup Menu -->
          <Popup x:Name="ToolsHoverPopup" 
           PlacementTarget="{Binding ElementName=toolsRadioButton}"
           Placement="Right"
           HorizontalOffset="-10"
           StaysOpen="True"
           AllowsTransparency="True">
            <Border Background="{DynamicResource MaterialDesign.Brush.Background}"
              BorderBrush="Gray" BorderThickness="1"
              CornerRadius="3"
              MouseEnter="ToolsHoverBorder_MouseEnter"
              MouseLeave="ToolsHoverBorder_MouseLeave">
              <StackPanel Margin="5">
                <RadioButton 
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowDataSourcesViewCommand}"
                 Click="ToolsHoverRadioButton_Click">
                  <StackPanel Orientation="Vertical">
                    <fa:IconImage Icon="Feed" Style="{StaticResource SideBarBtnIconStyle}" />
                    <TextBlock Text="Data Sources" Style="{StaticResource SideBarBtnTextStyle}" />
                  </StackPanel>
                </RadioButton>

                <RadioButton 
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowDataSourcesView2Command}"
                 Click="ToolsHoverRadioButton_Click">
                  <StackPanel Orientation="Vertical">
                    <fa:IconImage Icon="Feed" Style="{StaticResource SideBarBtnIconStyle}" />
                    <TextBlock Text="Data Sources V2" Style="{StaticResource SideBarBtnTextStyle}" />
                  </StackPanel>
                </RadioButton>

                <RadioButton 
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowDatabaseViewerViewCommand}"
                 Click="ToolsHoverRadioButton_Click">
                  <StackPanel Orientation="Vertical">
                    <fa:IconImage Icon="Database" Style="{StaticResource SideBarBtnIconStyle}" />
                    <TextBlock Text="Database Viewer" Style="{StaticResource SideBarBtnTextStyle}" />
                  </StackPanel>
                </RadioButton>
              </StackPanel>
            </Border>
          </Popup>

          <RadioButton Grid.Row="9"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding ShowSettingsViewCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="Gear" Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Settings" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>

          <RadioButton Grid.Row="10"
                 Style="{StaticResource SideBarButtonStyle}"
                 Tag="{StaticResource sideBarBtnColor}"
                 Command="{Binding LogoutButtonCommand}">
            <StackPanel Orientation="Vertical">
              <fa:IconImage Icon="RightFromBracket"  Style="{StaticResource SideBarBtnIconStyle}" />
              <TextBlock Text="Logout" Style="{StaticResource SideBarBtnTextStyle}" />
            </StackPanel>
          </RadioButton>
        </Grid>

        <!-- +++++++++++++++++++++++++++++ Main Content Area +++++++++++++++++++++++++++ -->

        <ContentControl Grid.Column="1" Padding="5"
                        prism:RegionManager.RegionName="ContentRegion" Style="{DynamicResource TransitioningContentBase}"/>
      </Grid>
    </Grid>

  </materialDesign:DialogHost>
  
</Window>